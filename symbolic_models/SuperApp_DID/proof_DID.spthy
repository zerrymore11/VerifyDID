    // loop breaker: [0]
  */

rule (modulo E) PresentationRequest[color=#f4c2c2]:
   [ !MF( $Verifier, openid, appid ), Fr( ~sess ), Fr( ~ShowReq ) ]
  --[
  Verifier( appid ),
  LVerifierShowPreReq( $Verifier, appid, ~ShowReq )
  ]->
   [
   St_MF_PresentReq( $Verifier, ~sess, openid, appid, ~ShowReq ),
   TLSClient_Out( 'GET', ~sess, $Verifier,
                  <'PresentationReq', appid, ~ShowReq>
   )
   ]

  /* has exactly the trivial AC variant */

restriction UniqueRole:
  "¬(∃ #i #j appid.
      (Issuer( appid ) @ #i) ∧ (Verifier( appid ) @ #j))"
  // safety formula

rule (modulo E) SuperAppConstructVPwithDisclosure[color=#6495ed]:
   [
   St_MF_PresentReq( $Verifier, sess, openid, appid, ~ShowReq ),
   TLSServer_In( 'GET', sess, $Verifer,
                 <'PresentationReq', appid, ~ShowReq>
   ),
   !SuperAppClient( $UserName, $Number, userid, appidPool ),
   !TEELTK( $Holder, userid, skH ), !MPK( $Verifier, appid, pkV ),
   !VC( (Issuer_signed_JWT++disclosure++sensitiveData) ),
   Fr( ~envelope_key )
   ]
  --[
  ValidMsg( appid, appidPool ),
  LHolderPresentVP( userid, appid, ~ShowReq,
                    <(Issuer_signed_JWT++disclosure), 
                     sign((Issuer_signed_JWT++disclosure), skH)>
  )
  ]->
   [
   TLSServer_Out( 'GET', sess, $Verifier,
                  <'PresentationVP', appid, 
                   senc(<(Issuer_signed_JWT++disclosure), 
                         sign((Issuer_signed_JWT++disclosure), skH)>,
                        ~envelope_key), 
                   aenc(~envelope_key, pkV)>
   )
   ]

  // loop breaker: [1]
  /* has exactly the trivial AC variant */

restriction replayReq:
  "∀ userid appid req VP1 VP2 #i #j.
    ((LHolderPresentVP( userid, appid, req, VP1 ) @ #i) ∧
     (LHolderPresentVP( userid, appid, req, VP2 ) @ #j)) ⇒
    (#i = #j)"
  // safety formula

rule (modulo E) MBVerifyPresentation[color=#f4c2c2]:
   [
   TLSClient_In( 'GET', sess, $Verifier,
                 <'PresentationVP', appid, 
                  senc(<(disclosure++<<prefixHash, postfixHash>, signature>), proof>,
                       envelope_key), 
                  aenc(envelope_key, pk(skV))>
   ),
   !MLTK( $Verifier, appid, skV ), !MPK( $Issuer, IssueID, pkI ),
   !TEEPK( $Holder, userid, pkH )
   ]
  --[
  Eq( checksign(proof,
                (disclosure++<<prefixHash, postfixHash>, signature>), pkH),
      true
  ),
  Eq( checksign(signature, <prefixHash, postfixHash>, pkI), true ),
  Eq( hash(disclosure), prefixHash ),
  LPresentationVerify( $Verifier, appid,
                       (disclosure++<<prefixHash, postfixHash>, signature>),
                       <(disclosure++<<prefixHash, postfixHash>, signature>), proof>
  )
  ]->
   [ ]

