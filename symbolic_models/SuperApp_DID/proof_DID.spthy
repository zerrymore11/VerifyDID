theory DID_ begin

// Function signature and definition of the equational theory E

builtins: multiset, natural-numbers
functions: SD_jwt/1, adec/2, aenc/2, checksign/3, fst/1, getEK/3,
           hash/1, maskedID/2, pair/2, pk/1, sdec/2, senc/2, sign/2, snd/1,
           true/0
equations:
    adec(aenc(x, pk(k)), k) = x,
    checksign(sign(m, k), m, pk(k)) = true,
    fst(<x.1, x.2>) = x.1,
    sdec(senc(x, k), k) = x,
    snd(<x.1, x.2>) = x.2

tactic: executability
presort: s
prio: {id}
  regex".*MF\(.*"
prio: {id}
  regex".*St_\(.*"
prio: {id}
  regex".*TLSServer_In\(.*"
prio: {id}
  regex".*TLSClient_In\(.*"
prio: {id}
  regex".*MB\(.*"
deprio: {id}
  regex".*⊏.*\+x.*"
deprio: {id}
  regex".*⊏.*"
deprio: {id}
  regex".*SuperAppClient\(.*"
deprio: {id}
  regex".*SuperAppServer\(.*"


tactic: test123
presort: s
prio: {id}
  regex".*MF\(.*"
prio: {id}
  regex".*St_\(.*"
prio: {id}
  regex".*TLSServer_In\(.*"
deprio: {id}
  regex".*SuperAppClient\(.*"


tactic: HolderPresentVP
presort: s
deprio: {id}
  regex".*⊏.*"



heuristic: o "oracleDID"





restriction equal:
  "∀ a b #i. (Eq( a, b ) @ #i) ⇒ (a = b)"
  // safety formula

rule (modulo E) Domain:
   [ ] --> [ !Domain( $Domain ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) DomainCompromise:
   [ !Domain( $Domain ) ]
  --[ CompromisedDomain( $Domain ), AdversaryActivity( ) ]->
   [ !DomainCompromise( $Domain ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) TLSClientOut[color=#ffffff]:
   [ TLSClient_Out( method, ~sess, $Domain, msg ), !Domain( $Domain )
   ]
  -->
   [ !TLSClient( method, ~sess, $Domain, msg ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) TLSServerOut[color=#ffffff]:
   [ TLSServer_Out( method, ~sess, $Domain, msg ), !Domain( $Domain )
   ]
  -->
   [ !TLSServer( method, ~sess, $Domain, msg ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) TLSClientToServer[color=#ffffff]:
   [ !TLSClient( method, ~sess, $Domain, msg ) ]
  -->
   [ TLSServer_In( method, ~sess, $Domain, msg ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) TLSServerToClient[color=#ffffff]:
   [ !TLSServer( method, ~sess, $Domain, msg ) ]
  -->
   [ TLSClient_In( method, ~sess, $Domain, msg ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Phone[color=#004225]:
   [ ]
  --[ ClaimNumber( $A, $Number ), IsPhoneNumber( $Number ) ]->
   [ !Phone( $A, $Number ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) InstallSuperAppClient[color=#6495ed]:
   [
   !Phone( $UserName, $Number ), Fr( ~userid ), Fr( ~sensitiveData ),
   Fr( ~disclosure ), Fr( ~k )
   ]
  --[ LInstallSuperApp( ~userid ) ]->
   [
   SuperApp( $UserName, $Number, ~userid, 'null' ),
   !TEELTK( $Holder, ~userid, ~k ),
   !TEEPK( $Holder, ~userid, pk(~k) ), Out( pk(~k) ),
   !DB( ~userid, ~disclosure, ~sensitiveData )
   ]

  /* has exactly the trivial AC variant */

restriction InstallOnce:
  "∀ userid1 userid2 #i #j.
    ((LInstallSuperApp( userid1 ) @ #i) ∧
     (LInstallSuperApp( userid2 ) @ #j)) ⇒
    (#i = #j)"
  // safety formula

rule (modulo E) registerDIDDocument[color=#6495ed]:
   [ !TEEPK( $Holder, ~userid, pubKey ) ]
  --[ LClientRegisterDIDdocument( ) ]->
   [ !DID( <'context', $context>, <'id', $id>, <'auth', pubKey> ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) MiniprogramRegister[color=#fff8e7]:
   [
   Fr( ~appid ), Fr( ~openid ), Fr( ~k ),
   SuperApp( $UserName, $Number, userid, appidPool )
   ]
  --[
  LPoolExpand( userid, appidPool ),
  LMiniprogramRegister( $A, userid, (~appid++appidPool) )
  ]->
   [
   MiniProgram( $A, ~openid, ~appid ), Out( pk(~k) ),
   !MLTK( $A, ~appid, ~k ), !MPK( $A, ~appid, pk(~k) ),
   !DID( <'context', $context>, <'id', $A>, <'auth', pk(~k)> ),
   SuperApp( $UserName, $Number, userid, (~appid++appidPool) )
   ]

  // loop breaker: [3]
  /* has exactly the trivial AC variant */

restriction IncreasingPool:
  "∀ userid Pool #i #j.
    ((LPoolExpand( userid, Pool ) @ #i) ∧
     (LPoolExpand( userid, Pool ) @ #j)) ⇒
    (#i = #j)"
  // safety formula

lemma firstInstall [reuse, use_induction]:
  all-traces
  "∀ userid Pool #i.
    (LPoolExpand( userid, Pool ) @ #i) ⇒
    (∃ #j. (LInstallSuperApp( userid ) @ #j) ∧ (#j < #i))"
/*
guarded formula characterizing all counter-examples:
"∃ userid Pool #i.
  (LPoolExpand( userid, Pool ) @ #i)
 ∧
  ∀ #j. (LInstallSuperApp( userid ) @ #j) ⇒ ¬(#j < #i)"
*/
by sorry

restriction PoolExpand:
  "∀ userid Pool1 Pool2 #i #j.
    (((LPoolExpand( userid, Pool1 ) @ #i) ∧
      (LPoolExpand( userid, Pool2 ) @ #j)) ∧
     (#i < #j)) ⇒
    (Pool1 ⊏ Pool2)"
  // safety formula

restriction RegisterOnce:
  "∀ A userid1 appidPool1 appidPool2 #i #j.
    ((LMiniprogramRegister( A, userid1, appidPool1 ) @ #i) ∧
     (LMiniprogramRegister( A, userid1, appidPool2 ) @ #j)) ⇒
    (#i = #j)"
  // safety formula

rule (modulo E) SAfrontendBackend:
   [ SuperApp( $UserName, $Number, userid, appidPool ) ]
  -->
   [
   !SuperAppClient( $UserName, $Number, userid, appidPool ),
   !SuperAppServer( $UserName, $Number, userid, appidPool )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) MiniProgramFrontEndBackEnd:
   [ MiniProgram( $A, openid, appid ) ]
  --[ LMPFrontend( $A, openid, appid ) ]->
   [ !MF( $A, openid, appid ), !MB( $A, openid, appid ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) AuthCodeRequest[color=#fdd5b1]:
   [ !MF( $Issuer, openid, appid ), Fr( ~sess ), Fr( ~req ) ]
  --[
  Issuer( appid ), LIssurerAuthCodeRequest( $Issuer, appid, ~req )
  ]->
   [
   St_MF_AuthCodeReq( $Issuer, ~sess, openid, appid ),
   TLSClient_Out( 'GET', ~sess, $Issuer, <'authCodeReq', appid, ~req>
   )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) SuperAppGenerateAuthCode[color=#6495ed]:
   [
   TLSServer_In( 'GET', ~sess, $Issuer, <'authCodeReq', appid, ~req>
   ),
   !SuperAppClient( $UserName, $Number, userid, appidPool ),
   Fr( ~authCode ), In( %lifeTime )
   ]
  --[
  ValidMsg( appid, appidPool ),
  LAuthCodeGenerate( userid, %lifeTime, ~authCode )
  ]->
   [
   TLSServer_Out( 'GET', ~sess, $Issuer,
                  <'authCode', appid, ~authCode>
   ),
   AuthCode( ~authCode )
   ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

restriction OneAuthCode:
  "∀ #i #j t1 t2 lifeTime1 lifeTime2 authCode1 authCode2.
    ((LAuthCodeGenerate( t1, lifeTime1, authCode1 ) @ #i) ∧
     (LAuthCodeGenerate( t2, lifeTime2, authCode2 ) @ #j)) ⇒
    (#i = #j)"
  // safety formula

rule (modulo E) MFgetAuthCode[color=#fdd5b1]:
   [
   St_MF_AuthCodeReq( $Issuer, sess, openid, appid ),
   TLSClient_In( 'GET', sess, $Issuer, <'authCode', appid, authCode>
   ),
   Fr( ~sessPost )
   ]
  --[ LMFGetAuthCode( $Issure, appid, authCode ) ]->
   [
   St_MF_GetAuthCode( $Issuer, openid, appid, authCode ),
   TLSClient_Out( 'POST', ~sessPost, $Issuer,
                  <'authCode', appid, authCode>
   )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) MBgetAuthCode[color=#fdfd96]:
   [
   St_MF_GetAuthCode( $Issuer, openid, appid, authCode ),
   TLSServer_In( 'POST', sess, $Issuer, <'authCode', appid, authCode>
   )
   ]
  --[ LMBGetAuthCode( $Issuer, appid, authCode ) ]->
   [ St_MB_GetAuthCode( $Issuer, openid, appid, authCode ) ]

  // loop breaker: [1]
  /* has exactly the trivial AC variant */

rule (modulo E) MBCallOauthToken[color=#fdfd96]:
   [
   St_MB_GetAuthCode( $Issuer, openid, appid, authCode ),
   Fr( ~sessToken )
   ]
  --[ LAuthCodeConsume( authCode ) ]->
   [
   TLSClient_Out( 'POST', ~sessToken, $Issuer,
                  <'tokenReq', appid, authCode>
   ),
   St_MB_TokenReq( $Issuer, openid, appid, authCode )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) SuperAppGenerateToken[color=#6495ed]:
   [
   TLSServer_In( 'POST', ~sess, $Issuer, <'tokenReq', appid, authCode>
   ),
   AuthCode( code ),
   !SuperAppServer( $UserName, $Number, userid, appidPool ),
   Fr( ~token )
   ]
  --[ Eq( code, authCode ), ValidMsg( appid, appidPool ) ]->
   [
   TLSServer_Out( 'POST', ~sess, $Issuer, <'token', appid, ~token> ),
   Token( ~token )
   ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

rule (modulo E) MBCallInfoShareAPI[color=#fdfd96]:
   [
   !MB( $Issuer, openid, appid ),
   St_MB_TokenReq( $Issuer, openid, appid, authCode ),
   TLSClient_In( 'POST', ~sess, $Issuer, <'token', appid, token> ),
   Fr( ~sessCall )
   ]
  -->
   [
   St_MB_CallInfoShare( $Issuer, openid, appid, token ),
   TLSClient_Out( 'GET', ~sessCall, $Issuer,
                  <'accessInfoReq', appid, token>
   )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) SuperAppReturnValue[color=#fdd5b1]:
   [
   TLSServer_In( 'GET', ~sess, $Issuer,
                 <'accessInfoReq', appid, token>
   ),
   Token( token ), !DB( userid, disclosure, sensitiveData ),
   !SuperAppServer( $UserName, $Number, userid, appidPool )
   ]
  --[ ValidMsg( appid, appidPool ) ]->
   [
   TLSServer_Out( 'GET', ~sess, $Issuer,
                  <'accessInfo', appid, disclosure, sensitiveData>
   )
   ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

rule (modulo E) MBgetSentitiveData[color=#fdfd96]:
   [
   St_MB_CallInfoShare( $Issuer, openid, appid, token ),
   TLSClient_In( 'GET', ~sess, $Issuer,
                 <'accessInfo', appid, disclosure, sensitiveData>
   )
   ]
  --[ LMBGetSensitiveData( appid, <disclosure, sensitiveData> ) ]->
   [ !MBDB( $Issuer, openid, appid, <disclosure, sensitiveData> ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) MBConstructCredential[color=#fdfd96]:
   [
   !MBDB( $Issuer, openid, appid, <disclosure, sensitiveData> ),
   !MLTK( $Issuer, appid, PrivKey ),
   !TEEPK( $Holder, userid, pubKey ), Fr( ~envelope_key ), Fr( ~sess )
   ]
  --[
  LCredentialIssurance( $Issuer, appid,
                        <
                         senc(<<hash(disclosure), hash(sensitiveData)>, 
                               sign(<hash(disclosure), hash(sensitiveData)>, PrivKey)>,
                              ~envelope_key), 
                         aenc(~envelope_key, pubKey)>
  )
  ]->
   [
   TLSClient_Out( 'POST', ~sess, $Issuer,
                  <'VC_data', appid, 
                   senc(<<hash(disclosure), hash(sensitiveData)>, 
                         sign(<hash(disclosure), hash(sensitiveData)>, PrivKey)>,
                        ~envelope_key), 
                   aenc(~envelope_key, pubKey)>
   )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) SuperAppStoreVC[color=#6495ed]:
   [
   TLSServer_In( 'POST', sess, $Issuer,
                 <'VC_data', appid, 
                  senc(<<hash(disclosure), hash(sensitiveData)>, signature>,
                       envelope_key), 
                  aenc(envelope_key, pk(skH))>
   ),
   !SuperAppClient( $UserName, $Number, userid, appidPool ),
   !MPK( $Issuer, appid, pkI ), !TEELTK( $Holder, userid, skH ),
   !DB( userid, disclosure, sensitiveData )
   ]
  --[
  Eq( checksign(signature, <hash(disclosure), hash(sensitiveData)>,
                pkI),
      true
  ),
  ValidMsg( appid, appidPool ),
  LSuperAppStoreVC( userid,
                    (disclosure++sensitiveData++
                     <<hash(disclosure), hash(sensitiveData)>, signature>)
  )
  ]->
   [
   !VC( (disclosure++sensitiveData++
         <<hash(disclosure), hash(sensitiveData)>, signature>)
   )
   ]

  // loop breaker: [0]
